    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <category android:name="android.intent.category.BROWSABLE"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
    <application android:name="com.xingyun.game.LayaApplication" android:icon="@mipmap/ic_launcher" android:roundIcon="@mipmap/ic_launcher_round" android:label="@string/app_name" android:theme="@style/Theme.AppCompat.NoActionBar" android:allowBackup="false" android:requestLegacyExternalStorage="true" tools:replace="android:allowBackup" android:usesCleartextTraffic="true">
        <!--xiaomi-->
        <meta-data android:name="notch.config" android:value="portrait"/>
        <!--huawei-->
