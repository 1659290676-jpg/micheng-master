        <activity android:configChanges="keyboard|keyboardHidden|screenLayout|screenSize|orientation" android:exported="false" android:name="cn.kkk.gamesdk.k3.login.LoginActivity" android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen" android:windowSoftInputMode="adjustResize|stateHidden|stateVisible" />
        
