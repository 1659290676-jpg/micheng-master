       <activity android:name="${applicationId}.GameActivity" android:theme="@style/ThemeWithoutAnim" android:screenOrientation="portrait" android:windowSoftInputMode="stateAlwaysHidden|adjustResize" android:launchMode="singleTop" android:configChanges="keyboard|keyboardHidden|screenLayout|screenSize|orientation" android:label="@string/app_name" android:exported="true">
