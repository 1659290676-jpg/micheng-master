        <meta-data android:name="BUGLY_APPID" android:value="9422668faf" />
        <meta-data android:name="BUGLY_ENABLE_DEBUG" android:value="false" />

		<activity android:configChanges="orientation|screenSize" android:name="com.bytedance.sdk.open.douyin.ui.DouYinWebAuthorizeActivity" android:screenOrientation="behind" android:theme="@android:style/Theme.NoTitleBar" />
			<activity android:exported="true" android:name="com.bytedance.sdk.open.douyin.impl.openapp.startapp.DouYinSDKEntryActivity" />
