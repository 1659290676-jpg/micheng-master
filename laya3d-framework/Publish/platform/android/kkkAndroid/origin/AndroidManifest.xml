        <activity android:configChanges="orientation|screenSize|keyboardHidden" android:exported="false" android:name="cn.kkk.gamesdk.fuse.FuseWebActivity" android:screenOrientation="portrait" android:theme="@android:style/Theme.NoTitleBar.Fullscreen" android:windowSoftInputMode="adjustResize" />
        
