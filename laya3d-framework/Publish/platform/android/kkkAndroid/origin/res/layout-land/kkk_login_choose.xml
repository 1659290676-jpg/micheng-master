<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/kkk_ll_parent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="30dp"
    android:paddingRight="30dp"
    android:background="#B3000000"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/ll_tv_login_hint"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:background="@drawable/kkk_tx_bg_black"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/kkk_tv_login_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="欢迎回来，123"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_go_switch_user"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="切换账号"
                android:textColor="@color/kkk_color_orange"
                android:layout_marginLeft="16dp"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/kkk_btn_cancel_auto_login"
            android:layout_width="200dp"
            android:layout_height="40dp"
            android:text="取消自动登录测试使用"
            android:layout_below="@+id/ll_tv_login_hint" />

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:orientation="horizontal">

        <GridLayout
            android:id="@+id/kkk_gl_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alignmentMode="alignMargins"
            android:columnCount="3"
            android:orientation="horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"/>

        <LinearLayout
            android:id="@+id/kkk_ll_xieyi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/kkk_gl_buttons"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/kkk_iv_check"
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@drawable/kkk_icon_checked" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:text="我已详细阅读并同意"
                android:textColor="#bfbfbf"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/kkk_tv_game_server"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="游戏用户服务协议"
                android:textColor="#0c7dd3"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="和"
                android:textColor="#bfbfbf"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/kkk_tv_game_private"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="隐私政策"
                android:textColor="#0c7dd3"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_go_login_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/kkk_ll_xieyi"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="14dp"
            android:text="最近登录账号"
            android:textColor="@color/kkk_color_orange"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/kkk_iv_age_level"
            android:layout_width="25dp"
            android:layout_height="30dp"
            android:layout_below="@id/tv_go_login_history"
            android:layout_marginTop="14dp"
            android:layout_centerHorizontal="true"
            android:src="@drawable/kkk_age_level_8" />
    </RelativeLayout>

</LinearLayout>