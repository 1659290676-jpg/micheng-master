<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="@dimen/kkk_login_bg_margin"
        android:layout_marginRight="@dimen/kkk_login_bg_margin"
        android:background="@drawable/kkk_login_account_act_bg_gray"
        android:orientation="vertical">

        <include layout="@layout/kkk_layout_titlebar" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/kkk_login_account_rl_title"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">


            <cn.kkk.gamesdk.k3.ui.RightEventEditText
                android:id="@+id/kkk_et_user"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_centerHorizontal="true"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="0dp"
                android:layout_marginRight="20dp" />


            <cn.kkk.gamesdk.k3.ui.RightEventEditText
                android:id="@+id/kkk_et_password"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_below="@+id/kkk_et_user"
                android:layout_centerHorizontal="true"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginRight="20dp" />

            <LinearLayout
                android:id="@+id/kkk_ll_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_et_password"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginRight="20dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/kkk_btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_below="@id/kkk_et_password"
                    android:layout_alignLeft="@id/kkk_et_password"
                    android:layout_marginLeft="0dp"
                    android:layout_marginRight="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/kkk_btn_bg_orange_selected"
                    android:text="登录"
                    android:textColor="@color/kkk_color_white"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/kkk_btn_register"
                    android:layout_width="90dp"
                    android:layout_height="40dp"
                    android:layout_below="@id/kkk_et_password"
                    android:layout_alignRight="@id/kkk_et_password"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="0dp"
                    android:background="@drawable/kkk_btn_bg_gray_selected"
                    android:text="快速注册"
                    android:textColor="@color/kkk_color_white"
                    android:textSize="14sp"
                    android:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/kkk_tv_go_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_ll_login"
                android:layout_marginTop="15dp"
                android:layout_centerHorizontal="true"
                android:autoLink="all"
                android:text="其他登录方式"
                android:textColor="@color/kkk_color_orange"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/kkk_tv_forget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_tv_go_back"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="14dp"
                android:autoLink="all"
                android:padding="4dp"
                android:textColor="@color/kkk_color_orange"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/kkk_iv_age_level"
                android:layout_width="25dp"
                android:layout_height="30dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="14dp"
                android:layout_below="@id/kkk_tv_go_back"
                android:src="@drawable/kkk_age_level_8" />

            <TextView
                android:id="@+id/kkk_tv_help"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_tv_go_back"
                android:layout_alignParentRight="true"
                android:layout_marginTop="14dp"
                android:layout_marginRight="16dp"
                android:padding="4dp"
                android:textColor="@color/kkk_color_blue"
                android:textSize="12sp" />
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
