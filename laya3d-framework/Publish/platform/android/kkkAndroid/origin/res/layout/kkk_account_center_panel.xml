<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_below="@+id/kkk_account_center_rl_title"
    android:background="@drawable/kkk_fragment_transparent"
    android:orientation="vertical"
    android:paddingLeft="10dp"
    android:paddingRight="10dp">

    <RelativeLayout
        android:id="@+id/kkk_content_top"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginLeft="2dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="2dp"
        android:layout_marginBottom="5dp">

        <cn.kkk.gamesdk.k3.ui.RoundImageView
            android:id="@+id/kkk_user_icon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_centerVertical="true" />

        <RelativeLayout
            android:id="@+id/kkk_user_info_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toRightOf="@id/kkk_user_icon"
            android:background="@android:color/transparent"
            android:orientation="vertical"
            android:paddingLeft="10dp">

            <TextView
                android:id="@+id/kkk_user_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="账号 : 1234556789"
                android:textColor="@color/kkk_color_white"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/kkk_user_account_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_user_account"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp"
                android:text="账号ID : 1234556789"
                android:textColor="@color/kkk_color_gray_100"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/kkk_user_bind_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_user_account_id"
                android:layout_marginTop="0dp"
                android:text="绑定ID : 1234556789"
                android:textColor="@color/kkk_color_white"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/kkk_copy_bind_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBottom="@id/kkk_user_bind_id"
                android:layout_marginLeft="10dp"
                android:layout_toRightOf="@id/kkk_user_bind_id"
                android:textColor="@color/kkk_color_orange"
                android:textSize="10sp" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <Button
                android:id="@+id/kkk_change_account"
                android:layout_width="80dp"
                android:layout_height="24dp"
                android:background="@drawable/kkk_btn_bg_light_blue"
                android:text="切换账号"
                android:textColor="@color/kkk_color_white"
                android:textSize="10sp" />

            <Button
                android:id="@+id/kkk_account_manager"
                android:layout_width="80dp"
                android:layout_height="24dp"
                android:layout_below="@id/kkk_user_account_id"
                android:layout_marginTop="14dp"
                android:background="@drawable/kkk_btn_bg_orange"
                android:text="账号管理"
                android:textColor="@color/kkk_color_white"
                android:textSize="10sp" />

        </LinearLayout>


    </RelativeLayout>

    <View
        android:id="@+id/kkk_content_line"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/kkk_color_gray" />

    <GridView
        android:id="@+id/kkk_feature_group"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="25dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="25dp"
        android:layout_marginBottom="10dp"
        android:layout_weight="3"
        android:columnWidth="100dp"
        android:horizontalSpacing="20dp"
        android:listSelector="#00000000"
        android:numColumns="3"
        android:verticalSpacing="20dp">

    </GridView>

</LinearLayout>