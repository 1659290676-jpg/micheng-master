<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp"
    android:background="@drawable/kkk_fuse_login_account_act_bg_gray"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <TextView
            android:id="@+id/kkk_fuse_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="青少年模式已开启"
            android:gravity="center"
            android:background="@drawable/kkk_fuse_login_account_title_bg_black"
            android:layout_centerHorizontal="true"
            android:textColor="@android:color/white"
            android:textSize="18sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/kkk_fuse_yinsi_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dip"
            >

            <TextView
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:id="@+id/kkk_fuse_dialog_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="您已进入青少年模式，将受到相关限制"
                android:layout_centerHorizontal="true"
                android:gravity="left"
                android:textColor="#505050"
                android:textSize="16sp"
                tools:ignore="RtlHardcoded" />

        </RelativeLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/kkk_fuse_dialog_close"
                android:layout_width="150dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="知道了"
                android:background="@drawable/kkk_fuse_btn_bg_orange"
                android:textColor="@android:color/white"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/kkk_fuse_parent_exit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="退出模式"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp"
                android:textColor="@color/kkk_fuse_color_orange"
                android:textSize="20sp">

            </TextView>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>