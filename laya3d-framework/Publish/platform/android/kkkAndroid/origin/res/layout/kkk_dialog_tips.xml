<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/kkk_dialog_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginBottom="10dip"
        android:src="@drawable/kkk_dialog_close" />

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/kkk_dialog_white_bg"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dip"
            android:padding="15dip">

            <TextView
                android:id="@+id/kkk_core_dialog_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:textColor="#000000"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/kkk_core_dialog_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_core_dialog_title"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dip"
                android:gravity="center_horizontal"
                android:textColor="#505050"
                android:textSize="15sp" />

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.3dip"
            android:background="#bebebe" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dip">

            <TextView
                android:id="@+id/kkk_dialog_left"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/kkk_color_orange"
                android:textSize="15sp" />

            <View
                android:id="@+id/kkk_dialog_action_line"
                android:layout_width="0.3dip"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:background="#bebebe" />

            <TextView
                android:id="@+id/kkk_dialog_right"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="#505050"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>