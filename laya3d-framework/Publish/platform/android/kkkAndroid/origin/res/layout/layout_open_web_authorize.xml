<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/open_rl_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/open_header_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/cancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:contentDescription="@string/aweme_open_web_auth_cancel"
            android:gravity="center"
            android:paddingStart="19dp"
            android:paddingLeft="19dp"
            android:paddingEnd="19dp"
            android:paddingRight="19dp"
            android:scaleType="centerInside"
            android:src="@drawable/openplatform_auth_backpress_icon" />

        <TextView
            android:id="@+id/auth_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_centerInParent="true"
            android:contentDescription="@string/aweme_open_auth_title"
            android:gravity="center"
            android:text="@string/aweme_open_auth_title"
            android:textColor="#161823"
            android:textSize="17sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:id="@+id/auth_top_divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_below="@+id/open_header_view"
        android:background="#1F161823" />

    <FrameLayout
        android:id="@+id/open_loading_group"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/auth_top_divider"
        android:visibility="gone"></FrameLayout>
</RelativeLayout>