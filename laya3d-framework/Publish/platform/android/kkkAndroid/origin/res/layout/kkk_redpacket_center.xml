<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:gravity="center">

    <RelativeLayout
        android:layout_width="350dp"
        android:layout_height="440dp"
        android:layout_gravity="center"
        android:background="@drawable/kkk_login_account_act_bg_gray">

        <RelativeLayout
            android:id="@+id/kkk_redpacket_center_rl_title"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/kkk_login_account_title_bg_black">


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="horizontal"
                >

            <ImageView
                android:id="@+id/kkk_iv_redpacket"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/kkk_redpacket_img" />

            <TextView
                android:id="@+id/kkk_tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dip"
                android:text="红包"
                android:textColor="@color/kkk_color_white"
                android:textSize="16sp"
                android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/kkk_iv_return"
                android:layout_width="29dp"
                android:layout_height="29dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="10dp"
                android:padding="2dp"
                android:src="@drawable/kkk_return_left_img" />

            <TextView
                android:id="@+id/kkk_tv_task_ruler"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentRight="true"
                android:layout_marginRight="20dp"
                android:text="活动规则"
                android:textColor="@color/kkk_color_orange"
                android:textSize="12sp" />

        </RelativeLayout>

        <FrameLayout
            android:id="@+id/kkk_redpacket_center_fl_container"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_below="@id/kkk_redpacket_center_rl_title" >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/kkk_frame_above_gray"
                    android:layout_margin="10dip"
                    android:padding="5dip"
                    android:orientation="vertical"
                    >

                    <RelativeLayout
                        android:id="@+id/kkk_redpacket_center_rl_line1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/kkk_btn_bind_phone"
                            android:layout_width="70dp"
                            android:layout_height="25dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/kkk_frame_gray"
                            android:text="绑定手机号"
                            android:textColor="@color/kkk_color_gray_100"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/kkk_tv_role_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="角色名称"
                            android:textColor="@color/kkk_color_white"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dip"
                            android:layout_below="@id/kkk_tv_role_name">

                            <TextView
                                android:id="@+id/kkk_redpacket_tv_role_level"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="角色等级"
                                android:textColor="@color/kkk_color_gray_100"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/kkk_tv_server_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:text="角色区服"
                                android:textColor="@color/kkk_color_gray_100"
                                android:textSize="10sp" />

                        </LinearLayout>

                    </RelativeLayout>

                    <View
                        android:id="@+id/kkk_view_line"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginTop="5dip"
                        android:layout_marginBottom="5dip"
                        android:layout_gravity="center_vertical"
                        android:background="@color/kkk_color_gray" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/kkk_redpacket_center_ll_line2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="红包总金额"
                                android:textColor="@color/kkk_color_white"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/kkk_tv_redpacket_total_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="10dp"
                                android:text="1718 元"
                                android:textColor="@color/kkk_color_orange_yellow"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/kkk_tv_end_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dip"
                            android:layout_below="@id/kkk_redpacket_center_ll_line2"
                            android:text="截止时间：2020年12月3日10:24:32"
                            android:textColor="@color/kkk_color_gray_100"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:id="@+id/kkk_redpacket_center_ll_line3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="我的红包 ¥"
                                android:textColor="@color/kkk_color_white"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/kkk_tv_redpacket_remain_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="2dp"
                                android:layout_marginStart="2dp"
                                android:text="180.1 元"
                                android:textColor="@color/kkk_color_orange_yellow"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <Button
                            android:id="@+id/kkk_btn_withdrawal_cash"
                            android:layout_width="70dp"
                            android:layout_height="25dp"
                            android:layout_alignParentRight="true"
                            android:layout_marginTop="2dip"
                            android:layout_below="@id/kkk_redpacket_center_ll_line3"
                            android:background="@drawable/kkk_btn_bg_orange"
                            android:text="立即提现"
                            android:textColor="@color/kkk_color_white"
                            android:textSize="12sp" />

                    </RelativeLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="10dip"
                    android:background="@drawable/kkk_frame_below_gray"
                    android:orientation="vertical"
                    >

                <cn.kkk.gamesdk.k3.redpack.ViewPagerIndicator.TabPageIndicator
                    android:id="@+id/kkk_indicator"
                    android:layout_height="wrap_content"
                    android:layout_width="fill_parent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/kkk_color_gray" />

                <android.support.v4.view.ViewPager
                    android:id="@+id/kkk_vp_tasks"
                    android:layout_width="fill_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

    </RelativeLayout>



</LinearLayout>