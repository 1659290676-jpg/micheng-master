<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:paddingLeft="5dip"
    android:paddingRight="5dip"
    android:paddingTop="5dip"
    android:paddingBottom="5dip"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/kkk_redpacket_item_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:src="@drawable/kkk_redpacket_item_icon" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginLeft="5dip"
        android:orientation="vertical"
        android:layout_toRightOf="@id/kkk_redpacket_item_icon">

        <TextView
            android:id="@+id/kkk_redpacket_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/kkk_color_white"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/kkk_redpacket_item_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/kkk_ac_item_icon"
            android:textColor="@color/kkk_color_gray_100"
            android:textSize="10sp" />
    </LinearLayout>

    <Button
        android:id="@+id/kkk_redpacket_item_status"
        android:layout_width="70dip"
        android:layout_height="25dip"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:gravity="center"
        android:background="@drawable/kkk_btn_bg_orange"
        android:padding="5dip"
        android:textSize="12sp"
        android:textColor="@color/kkk_color_white" />

</RelativeLayout>