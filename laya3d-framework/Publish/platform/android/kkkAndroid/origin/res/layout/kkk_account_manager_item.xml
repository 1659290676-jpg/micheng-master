<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/kkk_item_key"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:text="name"
        android:textColor="@color/kkk_color_white"
        android:textSize="12sp"
        android:gravity="left|center_vertical"/>

    <TextView
        android:id="@+id/kkk_item_value"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_weight="2"
        android:gravity="right|center_vertical"
        android:text=""
        android:textColor="@color/kkk_color_white"
        android:textSize="12sp"
        android:visibility="gone" />

    <cn.kkk.gamesdk.k3.ui.RoundImageView
        android:id="@+id/kkk_item_icon"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/kkk_user_icon_img"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/kkk_item_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:src="@drawable/kkk_right_arrow"
        android:visibility="gone"/>


</LinearLayout>