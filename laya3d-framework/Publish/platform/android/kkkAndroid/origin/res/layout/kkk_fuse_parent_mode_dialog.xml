<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/kkk_fuse_login_account_act_bg_gray">

    <RelativeLayout
        android:id="@+id/kkk_fuse_account_center_rl_title"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/kkk_fuse_login_account_title_bg_black">

        <TextView
            android:id="@+id/kkk_fuse_tv_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="青少年模式"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/kkk_fuse_iv_return"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="20dp"
            android:padding="2dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/kkk_fuse_iv_header_close"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="2dp"
            android:src="@drawable/kkk_fuse_header_close"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/kkk_fuse_title_tab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/kkk_fuse_tv_title_left"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="用户协议"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/kkk_fuse_title_tab_line"
                android:layout_width="0.8dp"
                android:layout_height="match_parent"
                android:background="#c3c3c3" />

            <TextView
                android:id="@+id/kkk_fuse_tv_title_right"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="隐私政策"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/kkk_fuse_yinsi_container"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_below="@id/kkk_fuse_account_center_rl_title"
        android:orientation="vertical"
        android:padding="10dp">


        <WebView
            android:id="@+id/kkk_fuse_parent_wv"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:layerType="software" />

        <LinearLayout
            android:id="@+id/kkk_ll_xieyi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/kkk_ll_login"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/kkk_iv_check"
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@drawable/kkk_fuse_icon_check" />

            <TextView
                android:id="@+id/kkk_tv_read_tips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:text="我已阅读并同意"
                android:textColor="#bfbfbf"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/kkk_tv_parent_xie_yi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《青少年模式协议须知》"
                android:textColor="#0c7dd3"
                android:textSize="14sp" />


        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/kkk_fuse_dialog_txt_mode"
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="开启青少年模式"
                android:textColor="@color/kkk_fuse_color_orange"
                android:textSize="16sp" />

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/kkk_fuse_dialog_btn_close"
                android:layout_width="150dp"
                android:layout_height="40dp"
                android:layout_centerInParent="true"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="15dp"
                android:background="@drawable/kkk_fuse_btn_bg_orange"
                android:text="关闭"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

        </RelativeLayout>


    </LinearLayout>
</RelativeLayout>