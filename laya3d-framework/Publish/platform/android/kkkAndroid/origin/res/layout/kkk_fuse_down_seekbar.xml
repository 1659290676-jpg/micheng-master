<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/kkk_fuse_dialog_bg"
    android:orientation="vertical">

    <TextView
        android:id="@+id/kkk_fuse_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/kkk_fuse_dialog_title_bg"
        android:gravity="center"
        android:text="标题"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="visible" />


    <ScrollView
        android:id="@+id/kkk_fuse_sv_content"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:padding="10dp">

        <TextView
            android:id="@+id/kkk_fuse_dialog_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:autoLink="all"
            android:gravity="left"
            android:textColor="#c2c2c2"
            android:textSize="12sp" />
    </ScrollView>

    <RelativeLayout
        android:id="@+id/kkk_fuse_rl_down"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/kkk_fuse_sv_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="0dip"
        android:gravity="bottom">

        <SeekBar
            android:id="@+id/kkk_fuse_seekbar"
            style="@android:style/Widget.SeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:indeterminateDrawable="@android:drawable/progress_indeterminate_horizontal"
            android:indeterminateOnly="false"
            android:maxHeight="8dp"
            android:minHeight="8dp"
            android:progressDrawable="@drawable/kkk_fuse_seekbar_horizontal"
            android:thumb="@android:color/transparent"
            android:thumbOffset="10dp" />

        <TextView
            android:id="@+id/kkk_fuse_tv_downspeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/kkk_fuse_seekbar"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text=""
            android:textColor="#c2c2c2" />

        <LinearLayout
            android:id="@+id/kkk_fuse_ll_do_to_web"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/kkk_fuse_tv_downspeed"
            android:layout_marginTop="4dp"
            android:gravity="center">

            <TextView
                android:id="@+id/kkk_fuse_tv_ps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="注：若无法自动下载，请点击此处"
                android:textColor="#c2c2c2"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/kkk_fuse_tv_do_to_web"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/kkk_fuse_seekbar"
                android:gravity="center"
                android:text="手动下载"
                android:textColor="@color/kkk_fuse_color_orange"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="。"
                android:textColor="#c2c2c2"
                android:textSize="12sp" />
        </LinearLayout>

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="7dp"
        android:background="#5d5d5d" />

    <LinearLayout
        android:id="@+id/kkk_fuse_dialog_bttom_ll"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/kkk_fuse_dialog_btn_left"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="action1"
            android:textColor="#fe8300"
            android:textSize="14sp" />

        <View
            android:id="@+id/kkk_fuse_dialog_line"
            android:layout_width="0.1dp"
            android:layout_height="match_parent"
            android:background="#5d5d5d" />

        <Button
            android:id="@+id/kkk_fuse_dialog_btn_right"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginRight="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="action2"
            android:textColor="#00d591"
            android:textSize="14sp"
            android:visibility="visible" />
    </LinearLayout>

</LinearLayout>