<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kkk_fragment_transparent"
    android:gravity="center"
    android:orientation="vertical">

    <cn.kkk.gamesdk.k3.ui.RightEventEditText
        android:id="@+id/kkk_reet_phone_number"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginLeft="50dp"
        android:layout_marginRight="50dp" />

    <Button
        android:id="@+id/kkk_btn_next"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_below="@id/kkk_reet_phone_number"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="50dp"
        android:layout_marginRight="50dp"
        android:background="@drawable/kkk_btn_selector"
        android:text="下一步"
        android:textColor="@color/kkk_color_white" />

</RelativeLayout>