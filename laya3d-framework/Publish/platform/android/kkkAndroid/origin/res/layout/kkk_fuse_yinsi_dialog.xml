<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/kkk_fuse_login_account_act_bg_gray">

    <RelativeLayout
        android:id="@+id/kkk_fuse_account_center_rl_title"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/kkk_fuse_login_account_title_bg_black">

        <TextView
            android:id="@+id/kkk_fuse_tv_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="适龄提示和隐私政策"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/kkk_fuse_iv_return"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="20dp"
            android:padding="2dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/kkk_fuse_iv_header_close"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:padding="2dp"
            android:src="@drawable/kkk_fuse_header_close"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/kkk_fuse_title_tab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/kkk_fuse_tv_title_left"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="用户协议"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/kkk_fuse_title_tab_line"
                android:layout_width="0.8dp"
                android:layout_height="match_parent"
                android:background="#c3c3c3" />

            <TextView
                android:id="@+id/kkk_fuse_tv_title_right"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="隐私政策"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/kkk_fuse_yinsi_container"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_below="@id/kkk_fuse_account_center_rl_title"
        android:orientation="vertical"
        android:padding="10dp">


        <WebView
            android:id="@+id/kkk_fuse_yinsi_wv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:layerType="software" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/kkk_fuse_btn_i_know"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/kkk_fuse_btn_bg_orange"
                android:text="我知道了"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/kkk_fuse_ll_confirm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/kkk_fuse_dialog_btn_let"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginRight="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/kkk_fuse_btn_cancel_bg"
                    android:text="不同意"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/kkk_fuse_dialog_btn_right"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/kkk_fuse_btn_bg_orange"
                    android:text="同意"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

            </LinearLayout>

        </RelativeLayout>


    </LinearLayout>
</RelativeLayout>